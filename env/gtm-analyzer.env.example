# ──────────────────────────────────────────────────────────────
# Production env file for vsea-gtm-analyzer-ai on vsea-hostinger-1.
# Copy to ./env/gtm-analyzer.env on the VM and fill in real values.
# Never commit the real file — .gitignore excludes env/*.env.
# ──────────────────────────────────────────────────────────────

# Anthropic API key — used by LiteLlm for the Claude Sonnet 4.6 analyze agents.
# /analyze endpoints will 502 if this is missing.
ANTHROPIC_API_KEY=

# Gemini AI Studio key (still required — ADK imports google-genai at startup
# even though the analyze path no longer hits Gemini).
GOOGLE_API_KEY=

# Shared secret required in X-API-Key header for all /analyze + /upload calls.
# The frontend embeds this; rotate if it leaks.
SERVICE_API_KEY=

# GCS bucket + SA path (SA is mounted into the container at /secrets/gcp-sa.json)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# CORS
# Exact-match allow-list (comma separated). Production frontends:
CORS_ORIGINS=https://www.venturesea.co,https://venturesea.co
# Regex allow-list for dev testing (localhost on any port + file:// which sends Origin=null).
# Leave blank in prod-only environments. The `null` alternation handles file:// (double-clicked HTML).
CORS_ORIGIN_REGEX=^(https?://(localhost|127\.0\.0\.1)(:\d+)?|null)$
