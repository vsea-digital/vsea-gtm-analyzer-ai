# Gemini API key (AI Studio). Do NOT commit the real key.
GOOGLE_API_KEY=

# Anthropic API key used by LiteLlm for the Claude Sonnet 4.6 agent.
ANTHROPIC_API_KEY=

# Optional: OpenAI-compatible proxy base URL for Anthropic traffic
# (e.g. https://venturesea-claude-proxy.onrender.com/). Leave blank to call
# Anthropic directly.
ANTHROPIC_API_BASE=

# Shared service key — frontend sends this in X-API-Key
SERVICE_API_KEY=vsea-gtm-dev-key

# GCS bucket for temporary uploaded pitch decks
GCS_BUCKET_NAME=vsea-gtm-uploads

# Absolute path to the GCP service-account JSON.
# Local dev: copy advisia-digital-gcp.json to ./secrets/gcp-sa.json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-sa.json

# CORS allow-list (comma separated). Use * in dev.
CORS_ORIGINS=*
